# VIM Canvas Demo App Environment Variables

# ScribeAI API Key
VITE_SCRIBEAI_API_KEY=your_scribeai_api_key_here

# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# API Base URL (ScribeAI Backend)
VITE_API_BASE_URL=https://api-scribeai-31058533dd54.herokuapp.com

# Signup URL - Configure for different environments
# Production: https://scribeai.live/signup
# Staging: https://scribeai-staging-56a3c2e3943e.herokuapp.com/signup
VITE_SIGNUP_URL=https://scribeai.live/signup

# Auth Configuration (if needed)
CLIENT_ID=your_client_id_here
CLIENT_SECRET=your_client_secret_here
REDIRECT_URL=http://localhost:8788 